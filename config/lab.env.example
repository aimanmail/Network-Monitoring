# Copy to lab.env and edit for your network (do not commit lab.env)
# Usage: source lab.env && bash scripts/fix-librenms-graphs.sh

# GNS3 router IP (change to match YOUR lab)
ROUTER_IP=192.168.67.1

# Router FastEthernet0/0 MAC from GNS3 (show interfaces f0/0 on R1)
ROUTER_MAC=c2:01:0b:71:00:00

# SNMP settings (must match router config)
SNMP_COMMUNITY=public
SNMP_VERSION=v2c

# Optional: force LibreNMS server interface (auto-detected if empty)
# LAB_IFACE=ens33
