APP_NAME=LibreNMS
APP_ENV=production
APP_DEBUG=false
# Set automatically by install-librenms-ubuntu.sh from this server's IP
# Or override: sudo LIBRENMS_APP_URL=http://YOUR_IP ./install-librenms-ubuntu.sh
APP_URL=http://AUTO_DETECT_ON_INSTALL

# Enable the official web setup wizard (removed by the wizard on finish)
INSTALL=true

# Generated on install: php artisan key:generate --force
APP_KEY=

# Database credentials are entered in the web setup wizard.
# The installer pre-creates an empty MariaDB database and user — see install output.
#DB_CONNECTION=mysql
#DB_HOST=localhost
#DB_PORT=3306
#DB_DATABASE=librenms
#DB_USERNAME=librenms
#DB_PASSWORD=
